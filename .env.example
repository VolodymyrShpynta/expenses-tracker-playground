# Environment Variables for Expenses Tracker API
# Copy this file to .env and update with your values

# ============================================
# Docker Compose Configuration
# ============================================
# These variables are used when running BOTH application and PostgreSQL in Docker Compose
# They override the defaults in application.yaml

# Database Configuration
POSTGRES_DB=expenses_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Application Configuration
# IMPORTANT: Use 'postgres' (service name) not 'localhost' when running in Docker Compose

# R2DBC Configuration (Reactive database connection)
EXPENSES_TRACKER_R2DBC_URL=r2dbc:postgresql://postgres:5432/expenses_db
EXPENSES_TRACKER_R2DBC_USERNAME=postgres
EXPENSES_TRACKER_R2DBC_PASSWORD=postgres

# Flyway Configuration (Database migrations)
EXPENSES_TRACKER_FLYWAY_JDBC_URL=jdbc:postgresql://postgres:5432/expenses_db
EXPENSES_TRACKER_FLYWAY_USERNAME=postgres
EXPENSES_TRACKER_FLYWAY_PASSWORD=postgres

# ============================================
# Optional Configuration
# ============================================

# Server port (default: 8080)
# SERVER_PORT=8080

# Active Spring profile (dev, test, prod, gdpr-local)
# `gdpr-local` enables the full GDPR subsystem (Art. 17 cascade to
# Keycloak + Art. 5(e) inactivity job with a 10-second cron) against the
# bundled docker-compose Keycloak realm. See
# `expenses-tracker-api/src/main/resources/application-gdpr-local.yaml`
# and the "Enabling the GDPR subsystem locally" section in README.md.
# SPRING_PROFILES_ACTIVE=gdpr-local

# ============================================
# GDPR subsystem overrides (only relevant when SPRING_PROFILES_ACTIVE
# includes `gdpr-local`). The defaults baked into the profile work fine
# for the docker-compose stack; override only when you need different
# timing or are pointing at a non-default Keycloak.
# ============================================
# GDPR_INACTIVITY_ENABLED=true
# GDPR_INACTIVITY_CRON=*/10 * * * * *
# GDPR_INACTIVITY_WARNING_AFTER=PT10M
# GDPR_INACTIVITY_GRACE=PT30M
# GDPR_RESTRICTION_LIFT_DWELL=PT30S
# GDPR_FRESH_AUTH_MAX_AGE=PT1H
# GDPR_ACTIVITY_DEBOUNCE=PT0S
# GDPR_KEYCLOAK_ADMIN_ENABLED=true
# GDPR_KEYCLOAK_ADMIN_URL=http://keycloak:8180/auth
# GDPR_KEYCLOAK_ADMIN_REALM=expenses-tracker
# GDPR_KEYCLOAK_ADMIN_CLIENT_ID=expenses-api-admin
# GDPR_KEYCLOAK_ADMIN_CLIENT_SECRET=local-dev-admin-secret

# ============================================
# Production Notes
# ============================================
# - Use strong passwords in production!
# - Never commit .env file to version control
# - Consider using Docker secrets for sensitive data
# - Use environment-specific values for each deployment
